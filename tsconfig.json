{
  "compilerOptions": {
    "target": "es2021",
    "module": "es6",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "lib": [
      "es2021",
      "dom"
    ]
  },
  "typeRoots": [
    "./src/office.d.ts",
    "./src/types.d.ts"
  ],
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "tests",
    "Exclude",
    "src/types.d.ts",
    "src/office.d.ts"
  ]
}